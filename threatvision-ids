#!/bin/bash

# ==============================================================================
# ThreatVision AI (SentinelX SOC) — CLI Controller Utility
# ==============================================================================

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

show_help() {
    echo -e "${BLUE}======================================================================${NC}"
    echo -e "          ${CYAN}ThreatVision AI — CLI System Command Utility${NC}"
    echo -e "${BLUE}======================================================================${NC}"
    echo -e "Usage: ${GREEN}threatvision-ids${NC} [command]"
    echo ""
    echo -e "${YELLOW}Commands:${NC}"
    echo "  start           Start both Dashboard and IDS Sniffer background services"
    echo "  stop            Stop both background services"
    echo "  restart         Restart both background services"
    echo "  status          Check running status and pid values of both services"
    echo "  logs-ids        Stream real-time log outputs of the IDS Sniffer engine"
    echo "  logs-dash       Stream real-time log outputs of the Dashboard server"
    echo "  config          Edit system configuration (/etc/threatvision-ids.conf)"
    echo "  interface [dev] Set default sniffing interface and restart the engine"
    echo "  open            Launch the SOC dashboard interface in the default browser"
    echo "  uninstall       Uninstall ThreatVision AI completely from the system"
    echo "  help            Show this help message"
    echo ""
}

# Ensure systemd is available
if ! command -v systemctl &> /dev/null; then
    echo -e "${RED}Error: Systemd is not available on this system.${NC}"
    exit 1
fi

case "$1" in
    start)
        echo -e "${YELLOW}[*] Starting ThreatVision AI background services...${NC}"
        sudo systemctl start threatvision-dashboard.service
        sudo systemctl start threatvision-ids.service
        echo -e "${GREEN}[+] Services started successfully!${NC}"
        ;;
    stop)
        echo -e "${YELLOW}[*] Stopping ThreatVision AI background services...${NC}"
        sudo systemctl stop threatvision-ids.service
        sudo systemctl stop threatvision-dashboard.service
        echo -e "${GREEN}[+] Services stopped successfully!${NC}"
        ;;
    restart)
        echo -e "${YELLOW}[*] Restarting ThreatVision AI background services...${NC}"
        sudo systemctl restart threatvision-dashboard.service
        sudo systemctl restart threatvision-ids.service
        echo -e "${GREEN}[+] Services restarted successfully!${NC}"
        ;;
    status)
        echo -e "${BLUE}--- ThreatVision AI Dashboard Daemon Status ---${NC}"
        systemctl status threatvision-dashboard.service --no-pager || true
        echo ""
        echo -e "${BLUE}--- ThreatVision AI IDS Sniffer Daemon Status ---${NC}"
        systemctl status threatvision-ids.service --no-pager || true
        ;;
    logs-ids)
        echo -e "${YELLOW}Streaming logs for threatvision-ids (Press Ctrl+C to exit):${NC}"
        journalctl -u threatvision-ids.service -f -n 50
        ;;
    logs-dash)
        echo -e "${YELLOW}Streaming logs for threatvision-dashboard (Press Ctrl+C to exit):${NC}"
        journalctl -u threatvision-dashboard.service -f -n 50
        ;;
    config)
        EDITOR=${EDITOR:-nano}
        echo -e "${YELLOW}[*] Opening configuration file: /etc/threatvision-ids.conf${NC}"
        sudo $EDITOR /etc/threatvision-ids.conf
        ;;
    interface)
        if [ -z "$2" ]; then
            echo -e "${RED}Error: Please specify the interface name (e.g., wlan0, eth0, or auto).${NC}"
            exit 1
        fi
        echo -e "${YELLOW}[*] Updating configuration interface to: $2...${NC}"
        # Check if the config file exists
        if [ ! -f "/etc/threatvision-ids.conf" ]; then
            echo -e "${RED}Error: Configuration file not found at /etc/threatvision-ids.conf${NC}"
            exit 1
        fi
        # Edit IDS_INTERFACE in config file
        sudo sed -i 's/^IDS_INTERFACE=.*/IDS_INTERFACE='$2'/' /etc/threatvision-ids.conf
        echo -e "${YELLOW}[*] Restarting IDS sniffer service...${NC}"
        sudo systemctl restart threatvision-ids.service
        echo -e "${GREEN}[+] Successfully updated network interface and restarted IDS!${NC}"
        ;;
    open)
        echo -e "${YELLOW}[*] Opening dashboard at http://127.0.0.1:5000/...${NC}"
        xdg-open http://127.0.0.1:5000/ &>/dev/null || echo -e "${RED}Failed to open browser automatically. Please open http://127.0.0.1:5000/ manually.${NC}"
        ;;
    uninstall)
        if [ -f "/opt/threatvision-ids/uninstall.sh" ]; then
            sudo /opt/threatvision-ids/uninstall.sh
        else
            echo -e "${RED}Error: Uninstaller script not found at /opt/threatvision-ids/uninstall.sh${NC}"
            exit 1
        fi
        ;;
    help|*|""|"-h"|"--help")
        show_help
        ;;
esac
